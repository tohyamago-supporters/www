---
/**
 * BlurImage — ブラー placeholder (LQIP / blur-up) 付きのレスポンシブ画像。
 *
 * 読み込み前に極小画像をぼかした下絵 (base64 data URI) を即時表示し、
 * 本画像が読み込まれたらその上にフェードインさせて遅延感を消す。
 * 下絵は blur-placeholder.ts がビルド時に生成する。レスポンシブ画像
 * (srcset/sizes) は astro.config.mjs の image.layout 設定で自動付与される。
 *
 * 形状 (角丸・枠線・アスペクト・影) はラッパー (`class`) に、画像の見え方
 * (object-fit・彩度フィルタ等) は `imgClass` に分けて渡す。ラッパーが下絵の
 * 背景を持ち、本画像がその上を覆う構造のため、角丸クリップには overflow-hidden
 * を含むコンテナ (例: Card) かラッパー自身の overflow-hidden が必要。
 */
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'
import { getBlurDataURL } from './blur-placeholder'

interface Props {
  src: ImageMetadata
  alt: string
  sizes?: string
  loading?: 'eager' | 'lazy'
  decoding?: 'async' | 'sync' | 'auto'
  fetchpriority?: 'high' | 'low' | 'auto'
  /**
   * 本画像をフェードインさせるか。既定 true。
   * ファーストビュー (LCP) の画像は opacity アニメーションが計測に響くため
   * false にして下絵の上へ即時表示する。
   */
  fade?: boolean
  /**
   * webp 出力品質 (0–100)。既定 62。景観・葉物など高詳細な写真でも、Astro 既定の
   * 高品質 (~80 相当) だと 750px 幅でも 200KiB 超になりモバイル回線で重い。62 なら
   * 体感差なく 2〜3 割軽くできる。より鮮明さが要る箇所は呼び出し側で上書きする。
   */
  quality?: number
  /** ラッパー (形状・余白・アスペクト・枠線など) に付けるクラス */
  class?: string
  /** 本画像 (object-fit やフィルタ) に付けるクラス */
  imgClass?: string
}

const {
  src,
  alt,
  sizes,
  // 非 LCP 画像の既定。LCP 画像は呼び出し側で loading="eager" 等を明示する。
  loading = 'lazy',
  decoding = 'async',
  fetchpriority,
  fade = true,
  quality = 62,
  class: className = '',
  imgClass = '',
} = Astro.props

const blur = await getBlurDataURL(src)
---

<div
  class:list={['lqip', className]}
  style={blur ? `background-image:url(${blur})` : undefined}
>
  <Image
    src={src}
    alt={alt}
    sizes={sizes}
    quality={quality}
    loading={loading}
    decoding={decoding}
    fetchpriority={fetchpriority}
    data-fade-in={fade ? '' : undefined}
    class:list={['lqip-img', imgClass]}
  />
</div>
