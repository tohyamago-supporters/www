---
import BaseLayout from '~/layouts/BaseLayout.astro'
import BlurImage from '~/components/BlurImage.astro'
import Container from '~/components/Container.astro'
import SectionHeading from '~/components/SectionHeading.astro'
import Card from '~/components/Card.astro'
import Button from '~/components/Button.astro'
import AccessMap from '~/components/AccessMap'
import {
  mapSearchUrl as mapUrl,
  directionsUrl,
  type MapPlace,
} from '~/components/googleMaps'
import mountsImage from '~/assets/mounts.jpg'

/*
 * アクセス案内 (/access)。README ロードマップの優先課題「アクセス案内」に対応。
 * 遠山郷は新幹線も高速道路の出口も遠い秘境で、移動が参加の最大の障壁になる。
 * そこで「電車＋レンタカー / 高速バス＋レンタカー / 自家用車 / 路線バス」の
 * 主要 4 ルートと、起点別 (名古屋・東京) の目安、時刻表リンク、現地の食事・宿泊
 * をまとめ、初めての来訪者が移動を具体的にイメージできるようにする。
 *
 * 注意: 集合場所は活動の時期・内容で変わるため、最終的な行き先は応募後の案内に従う。
 * 当ページは「遠山郷／下栗の里までの一般的な行き方」を示す入口として用意する。
 */

const ACTIVO_URL = 'https://activo.jp/s/a/119414'

// 下栗の里 (主な活動エリア)。集合場所は応募後に案内する。
const DEST_QUERY = '長野県飯田市上村下栗1296'
const destinationPlace: MapPlace = {
  name: '下栗の里',
  // 「日本のチロル」と呼ばれる下栗集落の中心付近。ピンの細かなずれは下の
  // リンク (住所クエリ) で吸収するため、地図は周辺を俯瞰できる縮尺で見せる。
  lat: 35.3748,
  lng: 137.9842,
  address: '長野県飯田市上村下栗',
  query: DEST_QUERY,
  category: 'destination',
}
const mapCenter = {
  lat: destinationPlace.lat,
  lng: destinationPlace.lng,
}

// Maps JavaScript API のブラウザキー。設定があればインタラクティブ地図 (AccessMap)
// を、無ければ API キー不要の埋め込み iframe をフォールバックとして表示する。
const mapsApiKey = import.meta.env.GOOGLE_MAPS_API_KEY

// 出発地からの道順リンクと、API キー不要の埋め込み地図 (JS 無効・キー未設定時の保険)。
const destDirectionsUrl = directionsUrl(DEST_QUERY)
const mapEmbedUrl = `https://maps.google.com/maps?q=${encodeURIComponent(DEST_QUERY)}&z=11&hl=ja&output=embed`

// 主要ルート (4 種)。おすすめ度の高い順に並べる。
// 公共交通は本数が限られるため、いずれも最後はレンタカー / タクシーで現地へ向かう。
// 当会の送迎はあくまで最後の手段で、安易に頼る前提では案内しない。
//
// 各ルートに「起点別の目安 (origins)」と「時刻表リンク (timetables)」を内包し、
// 行き方カード 1 枚でその手段の所要時間と参照先まで完結させる (旧・独立セクションを統合)。
// - origins.time は代表的な便の一例 / おおよそのトータル時間。改定で変わるため目安。
// - 車は時刻表が無いため timetables は空。路線バスは起点別の目安を出さない (上町まで＋タクシー前提)。
const routes = [
  {
    id: 'car',
    badge: '自家用車',
    recommend: true,
    title: '中央道・三遠南信道で下栗へ',
    summary:
      '乗り換えなしで現地まで行け、現地でも自由に動けるため、山あいの遠山郷にはいちばんおすすめの方法です。高速を降りてからは細い山道が続くので、時間に余裕をもってお越しください。',
    steps: [
      '中央自動車道「飯田IC」または「座光寺スマートIC」で高速を降ります。',
      '三遠南信自動車道に入り、「程野IC」で降ります。',
      '国道152号へ出て、上村小学校の手前を左折。あとは道なりに山道を登ると下栗の里です。',
    ],
    origins: [
      {
        from: '名古屋から',
        time: 'トータル約3時間（中央道〜三遠南信道〜下栗）',
      },
      {
        from: '東京から',
        time: 'トータル約4時間半〜5時間（中央道〜三遠南信道〜下栗）',
      },
    ],
    timetables: [],
    note: '下栗周辺は道幅が狭く、すれ違いに注意が必要です。譲り合ってゆっくり走行してください。冬季は積雪・凍結に備えてください。',
  },
  {
    id: 'train',
    badge: '電車 ＋ レンタカー',
    recommend: false,
    title: 'JR飯田線で飯田駅へ',
    summary:
      '豊橋または豊川で JR 飯田線に乗り換え、飯田駅で降りてレンタカーで遠山郷へ。公共交通でお越しの場合に分かりやすいルートです。',
    steps: [
      '名古屋・東京方面から、まず東海道新幹線などで豊橋駅へ。',
      '豊橋駅（または豊川駅）で JR 飯田線に乗り換え、飯田駅まで。特急「伊那路」なら豊橋〜飯田はおよそ 2 時間半（1 日 2 往復）。普通列車もありますが本数・所要時間にご注意ください。',
      '飯田駅周辺でレンタカーを借り、遠山郷（下栗）へ。飯田市街から下栗まではおよそ 1 時間の山道です。',
    ],
    origins: [
      {
        from: '名古屋から',
        time: '名古屋 →〔東海道線・新幹線で約30分〜1時間〕→ 豊橋 10:09発「特急 伊那路1号」→ 飯田 12:41着',
      },
      {
        from: '東京から',
        time: '東京 →〔新幹線で約1時間20分〕→ 豊橋 10:09発「特急 伊那路1号」→ 飯田 12:41着',
      },
    ],
    timetables: [
      {
        label: 'JR飯田線 特急「伊那路」時刻表',
        href: 'https://ekitan.com/transit/express/train/exm-114569',
        note: '豊橋・豊川〜飯田。日中に着くのは伊那路1号のみ。',
      },
    ],
    note: '飯田線は本数が少ない区間です。日中に飯田へ着く特急「伊那路」は1日1本（伊那路1号）だけで、乗り遅れると次は夜着の伊那路3号（豊橋 18:20発）になります。乗り換え時刻は事前にご確認ください。',
  },
  {
    id: 'bus',
    badge: '高速バス ＋ レンタカー',
    recommend: false,
    title: '中央道の高速バスで伊賀良へ',
    summary:
      '新宿・名古屋から高速バスで「伊賀良（いがら）」へ。バス停周辺でレンタカーを借りて遠山郷へ向かいます。座って移動でき、運賃も控えめです。',
    steps: [
      '新宿（バスタ新宿）または名古屋から、中央道経由の高速バスに乗車。',
      '「伊賀良」バス停で下車（新宿からおよそ 4 時間、名古屋からはより短時間）。飯田 IC のすぐ近くです。',
      '伊賀良・飯田 IC 周辺でレンタカーを借り、遠山郷（下栗）へ。',
    ],
    origins: [
      {
        from: '名古屋から',
        time: '名鉄バスセンター 8:00発 → 伊賀良 約9:55／飯田駅前 10:01着（最速 約2時間）',
      },
      {
        from: '東京から',
        time: 'バスタ新宿 6:55発 → 伊賀良 10:48着（始発・最速 約3時間50分）',
      },
    ],
    timetables: [
      {
        label: '中央高速バス 新宿〜飯田（伊賀良に停車）',
        href: 'https://www.highwaybus.com/gp/info/timeTbl?lineGroupNo=1&lineId=130',
        note: 'バスタ新宿〜飯田。伊賀良で下車。',
      },
      {
        label: '名鉄バス 名古屋⇔飯田',
        href: 'https://www.meitetsu-bus.co.jp/express/iida',
        note: '名古屋方面からの高速バス。',
      },
    ],
    note: '便によって停車するバス停が異なります。「伊賀良」に停まる便かどうか、予約時にご確認ください。',
  },
  {
    id: 'localbus',
    badge: '路線バス（上町）',
    recommend: false,
    title: '路線バスで上町まで（上級者向け）',
    summary:
      'レンタカーを使わない場合は、飯田駅前から信南交通の遠山郷線で「上町（かみまち）」へ。ただし上町から下栗の集落までは距離があり、最後はタクシーなどでの移動が前提になります。',
    steps: [
      '飯田駅前から信南交通「遠山郷線」に乗車し、「上町」バス停で下車。',
      '上町から下栗の集落までは山道を約 7〜8km・標高差およそ 500m 登る必要があり、健脚の方でも徒歩でおよそ 2 時間かかります。徒歩での登坂は現実的ではありません。',
      'そのため上町からはタクシー（約 15 分）の利用が基本です。宿泊先によっては送迎が受けられる場合もあるため、予約時にご確認ください。',
    ],
    origins: [],
    timetables: [
      {
        label: '信南交通 遠山郷線（路線バス・飯田駅前〜上町ほか）',
        href: 'https://www.shinnan.co.jp/sb/time_E1_01.html',
        note: '飯田駅前から上町方面の路線バス時刻表。',
      },
      {
        label: '南信州公共交通（遠山郷線 E1）',
        href: 'https://kk.minami.nagano.jp/sheet/bus/e1/',
        note: '遠山郷エリアのバス路線まとめ。',
      },
    ],
    note: '路線バスは本数が限られ、現地までの移動手段を自分で確保する必要があります。どうしても手段が見つからない場合に限り、当会へご相談ください（送迎の確約はできません）。',
  },
]

// 食事処。当会の参加者がよく利用する 2 軒をおすすめとして主に紹介する。
// （営業時間・定休日は変わることがあるため、お出かけ前に各施設の最新情報を確認する旨を添える）
// lat/lng は地図ピン用。★要確認: 現状は概略値。正確な値は Google マップで対象を
// 右クリック →「緯度・経度をコピー」で取得して差し替える（リンクは map クエリで
// 開くため多少ずれても着地は正確）。
const restaurants = [
  {
    name: '食事処 いっ福',
    area: '下栗',
    desc: '下栗の郷土料理を味わえる食事処。旬の野菜や採れたて山菜の天ぷらが付く「いっ福定食」が名物です。',
    info: 'TEL 0260-36-2613（飯田市上村下栗）／不定休で営業時間もおおらか。お出かけ前に一度お電話を',
    detail: 'https://tohyamago.com/archives/14052',
    map: '長野県飯田市上村下栗 いっ福',
    lat: 35.3722, // ★要確認
    lng: 137.982, // ★要確認
  },
  {
    name: '豊坂屋',
    area: '程野',
    desc: '古民家でいただく、上村・遠山郷の郷土料理たっぷりの定食。古民家カフェも併設し、季節のパフェやドリンクも楽しめます。',
    info: 'TEL 0260-31-0506／10:00〜16:00（L.O.15:30、夜は要相談）。営業日はInstagramの営業カレンダーをご確認ください（飯田市上村程野）',
    detail: 'https://www.instagram.com/toyosakaya.129/',
    map: '長野県飯田市上村程野 豊坂屋',
    lat: 35.3966, // ★要確認
    lng: 137.9585, // ★要確認
  },
]

// 宿泊施設。こちらも参加者がよく利用する 3 軒をおすすめとして主に紹介する。
// lat/lng は上記「食事処」と同様、★要確認の概略値。
const stays = [
  {
    name: 'ゲストハウス太陽堂',
    area: '南信濃',
    desc: '旧商店をリノベーションした小さな素泊まりの宿。男女別ドミトリーと個室があり、共用キッチンで自炊も可能。カフェ&バルを併設し、温泉「かぐらの湯」へは徒歩 8 分です。',
    info: 'ドミトリー1泊4,000円〜／個室1名8,200円〜（飯田市南信濃和田・和田バス停から徒歩5分）',
    detail: 'https://tohyamago-taiyodo.com/',
    map: '長野県飯田市南信濃和田1496-2 遠山郷ゲストハウス太陽堂',
    lat: 35.2896, // ★要確認
    lng: 137.8993, // ★要確認
  },
  {
    name: 'かぐら山荘',
    area: '南信濃',
    desc: 'ログハウスの宿。夕食には下栗芋や豆腐田楽など、地元の味が並びます。温泉「かぐらの湯」から徒歩 1 分です。',
    info: 'TEL 0260-34-5777（飯田市南信濃・かぐらの湯すぐ）',
    detail: 'https://kagurasansou.com/',
    map: '遠山郷 かぐら山荘',
    lat: 35.2872, // ★要確認
    lng: 137.8935, // ★要確認
  },
  {
    name: '高原ロッジ下栗',
    area: '下栗',
    desc: '天空の里ビューポイントに最も近い宿。和洋の客室があり、宿泊者向けに下栗の里までの送迎（要予約）もあります。',
    info: 'TEL 0260-36-2758（飯田市上村下栗）',
    detail: 'https://www.tiroljapan.com/',
    map: '長野県飯田市上村下栗 高原ロッジ下栗',
    lat: 35.3712, // ★要確認
    lng: 137.9812, // ★要確認
  },
]

// 地図に立てるピン一覧: 目的地 + 食事処 + 宿。カテゴリで色分けし、AccessMap 側で
// 全ピンが収まるよう自動フィットする。
const mapPlaces: MapPlace[] = [
  destinationPlace,
  ...restaurants.map(
    (r): MapPlace => ({
      name: r.name,
      lat: r.lat,
      lng: r.lng,
      address: `${r.area}（食事処）`,
      query: r.map,
      category: 'food',
    }),
  ),
  ...stays.map(
    (s): MapPlace => ({
      name: s.name,
      lat: s.lat,
      lng: s.lng,
      address: `${s.area}（宿）`,
      query: s.map,
      category: 'stay',
    }),
  ),
]
---

<BaseLayout
  title="アクセス案内"
  description="遠山郷・下栗の里への行き方。電車＋レンタカー／高速バス＋レンタカー／自家用車／路線バスの主要ルートと、起点別の目安・時刻表、現地の食事処・宿泊をまとめました。"
  image={mountsImage}
  imageAlt="遠山郷の山並み"
>
  <!-- ヒーロー -->
  <section
    class="relative overflow-hidden bg-gradient-to-b from-sky-soft via-base to-base px-4 pt-12 pb-10 text-center sm:pt-16"
  >
    <span
      class="mx-auto mb-4 flex w-fit items-center rounded-full bg-primary-deep px-4 py-1 font-serif text-sm tracking-wide text-white"
    >
      アクセス案内
    </span>
    <h1
      class="font-serif text-3xl font-medium leading-snug text-primary md:text-4xl"
    >
      秘境への、行き方ガイド
    </h1>
    <p
      class="mx-auto mt-5 max-w-xl text-left leading-loose text-body sm:text-center"
    >
      遠山郷は、新幹線の駅も高速道路の出口も遠い、山あいの里。たどり着くまでの道のりも、この土地らしさのひとつです。はじめての方が迷わないよう、主な行き方と、現地での食事・宿泊をまとめました。
    </p>
    <div class="mx-auto mt-8 w-full max-w-3xl">
      <BlurImage
        src={mountsImage}
        alt="遠山郷の山並み"
        loading="eager"
        fetchpriority="high"
        fade={false}
        sizes="(min-width: 768px) 768px, 100vw"
        class="aspect-video w-full overflow-hidden rounded-3xl shadow-lg ring-1 ring-primary/10"
        imgClass="h-full! w-full object-cover"
      />
    </div>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <Button href="#routes">行き方を見る</Button>
      <Button href="/join" variant="outline">はじめての方へ</Button>
    </div>
  </section>

  <Container size="wide" class="py-12 md:py-16">
    <!-- はじめに (集合場所の注意) -->
    <section class="mb-16">
      <Card class="border-l-4 border-l-sky px-6 py-6 md:px-8">
        <div class="space-y-4 leading-loose text-body">
          <p class="indent-4">
            活動は <span class="font-medium text-primary-deep"
              >長野県飯田市の遠山郷</span
            >
            を中心に行っています。現在は「日本のチロル」とも呼ばれる
            <span class="font-medium text-primary-deep">下栗の里</span>
            での農作業が中心ですが、活動場所は時期や内容によって変わります。<span
              class="font-medium text-primary-deep"
              >当日の集合場所は、応募後にご案内します。</span
            >このページは、まず遠山郷・下栗までたどり着くための一般的な行き方としてご覧ください。
          </p>
          <p class="indent-4">
            山あいのため公共交通の便は限られ、<span
              class="font-medium text-primary-deep">お車が便利な地域</span
            >です。現地までの移動は、レンタカーやタクシーでご自身で向かっていただくのが基本となります。どうしても手段が見つからない場合に限り当会でご相談に応じますが、送迎をお約束できるものではありません。
          </p>
        </div>
        <div class="mt-6 flex flex-wrap gap-3">
          <Button href={mapUrl('長野県飯田市下栗1296')} variant="outline"
            >主な活動エリアの地図</Button
          >
        </div>
      </Card>
    </section>

    <!-- 行き方を選ぶ -->
    <section id="routes" class="mb-16 scroll-mt-24">
      <SectionHeading as="h2" align="left" class="mb-4"
        >行き方を選ぶ</SectionHeading
      >
      <p class="mb-6 leading-loose text-body">
        目的に合う行き方をお選びください。各カードに、主要な出発地（名古屋・東京）からの所要時間の目安と、参考になる時刻表リンクをまとめています。所要時間・時刻は時期や便で変わるため、おおよその目安としてご覧のうえ、出発前に各社の最新情報をご確認ください。
      </p>
      <div class="grid gap-6 md:grid-cols-2">
        {
          routes.map((route) => (
            <Card class="flex h-full flex-col border-t-4 border-t-primary-soft px-6 py-6 md:px-8">
              <div class="flex flex-wrap items-center gap-2">
                <span class="rounded-full bg-primary-deep px-3 py-0.5 text-[0.7rem] font-medium tracking-wide text-white">
                  {route.badge}
                </span>
                {route.recommend && (
                  <span class="rounded-full bg-accent-strong px-2.5 py-0.5 text-[0.65rem] font-medium tracking-wide text-white">
                    おすすめ
                  </span>
                )}
              </div>
              <h3 class="mt-3 font-serif text-lg font-medium text-primary">
                {route.title}
              </h3>
              <p class="mt-2 leading-relaxed text-body">{route.summary}</p>
              <ol class="mt-4 space-y-3">
                {route.steps.map((step, i) => (
                  <li class="flex gap-3 leading-relaxed text-body">
                    <span
                      class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-primary-soft/30 text-sm font-medium text-primary-deep"
                      aria-hidden="true"
                    >
                      {i + 1}
                    </span>
                    <span>{step}</span>
                  </li>
                ))}
              </ol>
              {route.origins.length > 0 && (
                <div class="mt-5 rounded-xl bg-primary-soft/10 px-4 py-3">
                  <p class="text-xs font-medium tracking-wide text-primary-deep">
                    起点別の目安
                  </p>
                  <dl class="mt-2 space-y-2 text-sm leading-relaxed text-body">
                    {route.origins.map((o) => (
                      <div class="flex gap-3">
                        <dt class="w-16 shrink-0 font-medium text-primary-deep">
                          {o.from}
                        </dt>
                        <dd>{o.time}</dd>
                      </div>
                    ))}
                  </dl>
                </div>
              )}
              {route.timetables.length > 0 && (
                <div class="mt-4">
                  <p class="text-xs font-medium tracking-wide text-primary-deep">
                    時刻表（参考）
                  </p>
                  <ul class="mt-2 space-y-2">
                    {route.timetables.map((t) => (
                      <li class="leading-relaxed">
                        <a
                          href={t.href}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="text-sm font-medium text-accent-strong underline decoration-accent/40 underline-offset-4 hover:decoration-accent focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
                        >
                          {t.label}
                        </a>
                        <span class="block text-xs text-body/80">{t.note}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              )}
              <p class="mt-4 rounded-xl bg-sunlight-soft/40 px-4 py-3 text-sm leading-relaxed text-body/90">
                {route.note}
              </p>
            </Card>
          ))
        }
      </div>
    </section>

    <!-- 地図とルート -->
    <section class="mb-16">
      <SectionHeading as="h2" align="left" class="mb-6"
        >地図とルート</SectionHeading
      >
      <Card class="overflow-hidden border-t-4 border-t-sky">
        <div class="aspect-video w-full bg-primary-soft/10">
          {
            mapsApiKey ? (
              <>
                <AccessMap
                  client:only="react"
                  apiKey={mapsApiKey}
                  center={mapCenter}
                  zoom={13}
                  places={mapPlaces}
                  openName={destinationPlace.name}
                />
                <noscript>
                  <iframe
                    title="下栗の里と周辺の地図"
                    src={mapEmbedUrl}
                    loading="lazy"
                    referrerpolicy="no-referrer-when-downgrade"
                    class="h-full w-full border-0"
                  />
                </noscript>
              </>
            ) : (
              <iframe
                title="下栗の里と周辺の地図"
                src={mapEmbedUrl}
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                class="h-full w-full border-0"
              />
            )
          }
        </div>
        <div class="px-6 py-6 md:px-8">
          {
            mapsApiKey && (
              <ul
                class="mb-4 flex flex-wrap gap-x-5 gap-y-2 text-sm text-body"
                aria-label="地図の凡例"
              >
                <li class="flex items-center gap-2">
                  <span
                    class="inline-block h-3 w-3 rounded-full ring-2 ring-white"
                    style="background:#c2410c"
                    aria-hidden="true"
                  />
                  目的地（下栗の里）
                </li>
                <li class="flex items-center gap-2">
                  <span
                    class="inline-block h-3 w-3 rounded-full ring-2 ring-white"
                    style="background:#b45309"
                    aria-hidden="true"
                  />
                  食事処
                </li>
                <li class="flex items-center gap-2">
                  <span
                    class="inline-block h-3 w-3 rounded-full ring-2 ring-white"
                    style="background:#1f6f43"
                    aria-hidden="true"
                  />
                  宿
                </li>
              </ul>
            )
          }
          <p class="leading-loose text-body">
            <span class="font-medium text-primary-deep">下栗の里</span
            >と、周辺の
            <span class="font-medium text-primary-deep">食事処・宿</span
            >をピンで示しています。{
              mapsApiKey && (
                <>ピンをタップすると、住所や経路リンクが開きます。</>
              )
            }自家用車では、三遠南信道「程野IC」から国道152号へ出て、<span
              class="font-medium text-primary-deep">上村小学校の手前を左折</span
            >し、山道を登ります。下のボタンから、お使いの出発地を起点にした道順（ルート）を確認できます。
          </p>
          <div class="mt-5 flex flex-wrap gap-3">
            <Button href={destDirectionsUrl}
              >Googleマップでルートを調べる</Button
            >
            <Button href={mapUrl(DEST_QUERY)} variant="outline"
              >地図を大きく開く</Button
            >
          </div>
        </div>
      </Card>
    </section>

    <!-- 食べる -->
    <section class="mb-16">
      <SectionHeading as="h2" align="left" class="mb-2">食べる</SectionHeading>
      <p class="mb-6 leading-loose text-body">
        活動の合間や前後に立ち寄れる、地元の食事処です。参加者がよく利用する 2
        軒をご紹介します。郷土の味で、ひと息ついてください。
      </p>
      <div class="grid gap-6 md:grid-cols-2">
        {
          restaurants.map((r) => (
            <Card class="flex h-full flex-col border-t-4 border-t-accent px-6 py-6">
              <div class="flex items-center gap-2">
                <h3 class="font-serif text-lg font-medium text-primary">
                  {r.name}
                </h3>
                <span class="rounded-full bg-primary-deep px-2.5 py-0.5 text-[0.65rem] font-medium tracking-wide text-white">
                  {r.area}
                </span>
              </div>
              <p class="mt-3 grow leading-relaxed text-body">{r.desc}</p>
              {r.info && <p class="mt-3 text-sm text-body/80">{r.info}</p>}
              <div class="mt-4 flex flex-wrap gap-2 text-sm">
                <a
                  href={r.detail}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="font-medium text-accent-strong underline decoration-accent/40 underline-offset-4 hover:decoration-accent focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
                >
                  詳しく見る
                </a>
                <span aria-hidden="true" class="text-body/30">
                  ／
                </span>
                <a
                  href={mapUrl(r.map)}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="font-medium text-primary underline decoration-primary/30 underline-offset-4 hover:decoration-primary focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
                >
                  地図
                </a>
              </div>
            </Card>
          ))
        }
      </div>
      <p class="mt-4 text-sm leading-relaxed text-body/80">
        営業時間や定休日は変わることがあります。お出かけ前に各施設の最新情報をご確認ください。このほかの飲食店は{
          ' '
        }
        <a
          href="https://tohyamago.com/archives/category/stay_and_eat/restaurant"
          target="_blank"
          rel="noopener noreferrer"
          class="font-medium text-accent-strong underline decoration-accent/40 underline-offset-4 hover:decoration-accent"
          >遠山郷観光協会「食べる」</a
        >
        もあわせてご覧ください。
      </p>
    </section>

    <!-- 泊まる -->
    <section class="mb-16">
      <SectionHeading as="h2" align="left" class="mb-2">泊まる</SectionHeading>
      <p class="mb-6 leading-loose text-body">
        遠方からお越しの方や、連日の活動には宿泊が便利です。参加者がよく利用する
        3 軒をご紹介します。山あいの夜と朝は、それだけで思い出になります。
      </p>
      <div class="grid gap-6 md:grid-cols-3">
        {
          stays.map((s) => (
            <Card class="flex h-full flex-col border-t-4 border-t-primary-soft px-6 py-6">
              <div class="flex items-center gap-2">
                <h3 class="font-serif text-lg font-medium text-primary">
                  {s.name}
                </h3>
                <span class="rounded-full bg-primary-deep px-2.5 py-0.5 text-[0.65rem] font-medium tracking-wide text-white">
                  {s.area}
                </span>
              </div>
              <p class="mt-3 grow leading-relaxed text-body">{s.desc}</p>
              {s.info && <p class="mt-3 text-sm text-body/80">{s.info}</p>}
              <div class="mt-4 flex flex-wrap gap-2 text-sm">
                <a
                  href={s.detail}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="font-medium text-accent-strong underline decoration-accent/40 underline-offset-4 hover:decoration-accent focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
                >
                  詳しく見る
                </a>
                <span aria-hidden="true" class="text-body/30">
                  ／
                </span>
                <a
                  href={mapUrl(s.map)}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="font-medium text-primary underline decoration-primary/30 underline-offset-4 hover:decoration-primary focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
                >
                  地図
                </a>
              </div>
            </Card>
          ))
        }
      </div>
      <p class="mt-4 text-sm leading-relaxed text-body/80">
        料金やプランは変わることがあります。ご予約前に各施設の最新情報をご確認ください。このほかの宿は{
          ' '
        }
        <a
          href="https://tohyamago.com/archives/category/stay_and_eat/stay"
          target="_blank"
          rel="noopener noreferrer"
          class="font-medium text-accent-strong underline decoration-accent/40 underline-offset-4 hover:decoration-accent"
          >遠山郷観光協会「泊まる」</a
        >
        もあわせてご覧ください。
      </p>
    </section>

    <!-- CTA -->
    <section
      class="rounded-3xl border border-primary/10 bg-gradient-to-br from-sunlight-soft/60 to-surface px-6 py-10 text-center md:px-12"
    >
      <SectionHeading as="h2" align="center" class="mb-4"
        >道のりも、旅のうち</SectionHeading
      >
      <p class="mx-auto max-w-xl leading-loose text-body">
        遠いぶんだけ、たどり着いたときの景色は格別です。ルートや時刻表でご不明な点があれば、お問い合わせください。あなたのお越しを、遠山郷でお待ちしています。
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <Button href={ACTIVO_URL}>ボランティア募集を見る</Button>
        <Button href="/join" variant="outline">はじめての方へ</Button>
      </div>
    </section>
  </Container>
</BaseLayout>
