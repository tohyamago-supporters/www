---
import { getImage } from 'astro:assets'
import type { ImageMetadata } from 'astro'
import SiteHeader from '~/components/SiteHeader.astro'
import SiteFooter from '~/components/SiteFooter.astro'
import Seo from '~/components/Seo.astro'
import {
  SITE_NAME,
  DEFAULT_DESCRIPTION,
  OG_IMAGE_WIDTH,
  OG_IMAGE_HEIGHT,
  buildTitle,
  canonicalPath,
  normalizeDescription,
  organizationJsonLd,
  websiteJsonLd,
} from '~/components/siteMeta'
import defaultOgImage from '~/assets/hero-photo.jpg'
import '~/styles/global.css'

interface Props {
  title?: string
  /** 検索スニペット / OGP の説明文。未指定なら団体の既定説明を使う。 */
  description?: string
  /** OG / Twitter カードの画像 (imported asset)。未指定ならヒーロー画像。 */
  image?: ImageMetadata
  /** OG 画像の代替テキスト。 */
  imageAlt?: string
  /** og:type。記事ページは 'article'。 */
  ogType?: 'website' | 'article'
  /** 検索エンジンに索引させない (404 等)。 */
  noindex?: boolean
  /** 記事公開日時 (article のとき og の article:published_time に使う)。 */
  publishedTime?: Date
  /** 記事タグ (article:tag)。 */
  tags?: string[]
  /** ページ固有の JSON-LD (記事・パンくず等)。Organization/WebSite に追記する。 */
  jsonLd?: Record<string, unknown>[]
  fullscreen?: boolean
}

const {
  title,
  description,
  image,
  imageAlt,
  ogType = 'website',
  noindex = false,
  publishedTime,
  tags = [],
  jsonLd = [],
  fullscreen = false,
} = Astro.props

const fullTitle = buildTitle(title)
const metaDescription = normalizeDescription(description ?? DEFAULT_DESCRIPTION)
const currentPath = Astro.url.pathname
// canonical / og:url。Astro.site (astro.config の site) を基点に絶対 URL 化する。
// build.format='file' で付く `.html` を実 URL に合わせて正規化してから絶対化する。
const canonicalURL = new URL(canonicalPath(currentPath), Astro.site).href

// OG/Twitter 画像は 1200x630 (推奨比) を JPEG で生成し絶対 URL 化する。
// 記事など固有画像が無ければサイト共通のヒーロー画像にフォールバックする。
const ogImage = await getImage({
  src: image ?? defaultOgImage,
  width: OG_IMAGE_WIDTH,
  height: OG_IMAGE_HEIGHT,
  fit: 'cover',
  format: 'jpeg',
})
const ogImageURL = new URL(ogImage.src, Astro.site).href
const ogImageAlt = imageAlt ?? (title ? `${title}｜${SITE_NAME}` : SITE_NAME)

// 構造化データ: 全ページに Organization + WebSite、加えてページ固有 (記事・パンくず)。
const siteHref = Astro.site?.href
const structuredData = [
  organizationJsonLd(siteHref),
  websiteJsonLd(siteHref),
  ...jsonLd,
]

// アクセス解析 (Google Analytics / gtag.js)。測定 ID は Cloudflare の環境変数
// GA_MEASUREMENT_ID で設定する。未設定 (ローカル開発・プレビュー) では計測タグを
// 出力しないため、開発中のアクセスが本番の解析に混ざらない。
const gaMeasurementId = import.meta.env.GA_MEASUREMENT_ID

// Google Fonts の CSS URL。非ブロッキング読み込み (preload / print swap / noscript) で
// 複数回参照するため定数化する。要求ウェイトは実使用分のみ (Serif 600 は不使用のため除外)。
const fontsHref =
  'https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500&family=Noto+Serif+JP:wght@300;500&display=swap'
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- 画像フェードイン (image-fade-in) のゲート。描画前に同期実行し、JS 有効時のみ
         未読込画像を透明化する。JS 無効ならクラスが付かず画像はそのまま表示される。 -->
    <script is:inline>
      document.documentElement.classList.add('js')
    </script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <Seo
      title={fullTitle}
      description={metaDescription}
      canonicalURL={canonicalURL}
      ogType={ogType}
      imageURL={ogImageURL}
      imageAlt={ogImageAlt}
      noindex={noindex}
      publishedTime={publishedTime?.toISOString()}
      tags={tags}
      structuredData={structuredData}
    />
    {
      /* Google tag (gtag.js)。GA_MEASUREMENT_ID が設定されているときのみ出力する。 */
      gaMeasurementId && (
        <Fragment>
          <script
            is:inline
            async
            src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`}
          />
          <script
            is:inline
            set:html={`window.dataLayer = window.dataLayer || [];
function gtag(){dataLayer.push(arguments);}
gtag('js', new Date());
gtag('config', '${gaMeasurementId}');`}
          />
        </Fragment>
      )
    }
    {
      /* タイポグラフィ: 見出し Noto Serif JP / 本文 Noto Sans JP (light 基調)。
        日本語 Web フォントは巨大 (ウェイトごとに ~100 個の unicode-range 分割) で、
        フォント CSS を render-blocking で読むと FCP/LCP が CSS ダウンロード完了まで
        待たされる (低速 4G で数秒)。そこで CSS を非ブロッキングに読み込む:
        まず media="print" で適用対象外として取得し、onload で media を all に戻す。
        display=swap によりまず system フォント (Hiragino/Yu 系) を即描画し、Web フォントは
        遅れて差し替える。JS 無効時は noscript の通常 stylesheet でフォールバックする。
        未使用ウェイト (Serif 600 = font-semibold は不使用) は要求しない。 */
    }
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href={fontsHref} />
    <link
      href={fontsHref}
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link href={fontsHref} rel="stylesheet" />
    </noscript>
  </head>
  <body class={fullscreen ? 'is-fullscreen' : undefined}>
    <SiteHeader currentPath={currentPath} />
    {
      fullscreen ? (
        /* 確定高さの body 内で grow + min-h-0。子の h-full が高さを解決できる */
        <main class="min-h-0 grow overflow-hidden">
          <slot />
        </main>
      ) : (
        /* main を grow させると、短いページでも SiteFooter が下端に収まる */
        <Fragment>
          <main class="grow">
            <slot />
          </main>
          <SiteFooter currentPath={currentPath} />
        </Fragment>
      )
    }
    <script>
      import { initImageFadeIn } from '~/components/image-fade-in'
      initImageFadeIn()
    </script>
  </body>
</html>
